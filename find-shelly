#!/bin/sh

RESULTS=$(mktemp)
HOSTS=$(mktemp)
trap 'rm -f $RESULTS $HOSTS' EXIT

# Start dns-sd in background
dns-sd -B _http._tcp local. >"$RESULTS" 2>&1 &
DNS_PID=$!

# Ensure dns-sd is killed on exit
trap 'kill $DNS_PID 2>/dev/null; rm -f $RESULTS $HOSTS' EXIT INT TERM

sleep 1

kill "$DNS_PID" 2>/dev/null

# Extract unique shelly hostnames
grep shelly "$RESULTS" | awk '{print $7}' >"$HOSTS"

cat "$HOSTS"

