{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "plugin": ["@ex-machina/opencode-anthropic-auth@1.7.0"],
  "agent": {
    "build": {
      "enable1mContext": true
    }
  },
  "mcp": {
    "ios-simulator": {
      "type": "local",
      "command": ["npx", "-y", "ios-simulator-mcp"],
      "enabled": true
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": true
    },
    "xcode": {
      "type": "local",
      "command": ["xcrun", "mcpbridge"],
      "enabled": true
    },
    "firebase": {
      "type": "local",
      "command": ["npx", "-y", "firebase-tools", "mcp", "--dir", "."],
      "enabled": true
    }
  }
}
