{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": true
    },
    "ios-simulator": {
      "type": "local",
      "command": ["npx", "-y", "ios-simulator-mcp"],
      "enabled": true
    },
    "xcode": {
      "type": "local",
      "command": ["xcrun", "mcpbridge"],
      "enabled": true
    }
  }
}
