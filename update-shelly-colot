#!/bin/sh

NEW_PEER="192.168.8.5:5683"
SUCCESS=0
FAILED=0

while read -r hostname; do
  # Skip empty lines
  [ -z "$hostname" ] && continue

  SETTINGS=$(curl -s "http://$hostname.local/settings")
  DEVICE_NAME=$(echo "$SETTINGS" | jq -r '.name // ""')
  OLD_PEER=$(echo "$SETTINGS" | jq -r '.coiot.peer // "<not set>"')

  if [ -n "$DEVICE_NAME" ]; then
    echo "Processing $DEVICE_NAME - $hostname"
  else
    echo "Processing $hostname"
  fi
  echo "  Current: $OLD_PEER"

  VERIFY=$(curl -s "http://$hostname.local/settings?coiot_peer=$NEW_PEER" | jq -r '.coiot.peer')

  if [ "$VERIFY" = "$NEW_PEER" ]; then
    echo "  ✓ Updated to: $NEW_PEER"
    SUCCESS=$((SUCCESS + 1))

    echo "  ⟳ Rebooting device..."
    curl -s "http://$hostname.local/reboot" >/dev/null
  else
    echo "  ✗ FAILED - still: $VERIFY"
    FAILED=$((FAILED + 1))
  fi
done

echo "====================="
echo "Done: $SUCCESS succeeded, $FAILED failed"
